# Ibha Web Application Environment Variables
# Copy this file to .env.local and fill in the values

# Catalyst API Base URL
NEXT_PUBLIC_CATALYST_API_BASE_URL=https://api.ibha.catalyst.zoho.com/v1

# Catalyst Auth Configuration
NEXT_PUBLIC_CATALYST_AUTH_ISSUER=https://accounts.zoho.com
NEXT_PUBLIC_CATALYST_CLIENT_ID=your_catalyst_client_id_here

# App Configuration
NEXT_PUBLIC_APP_NAME=Ibha
NEXT_PUBLIC_APP_VERSION=0.1.0

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_VOICE_MODE=true
NEXT_PUBLIC_ENABLE_NETWORK_VIEW=true
NEXT_PUBLIC_ENABLE_TRENDS_VIEW=true
NEXT_PUBLIC_ENABLE_INGESTION=true

# Development Settings
NEXT_PUBLIC_DEBUG_MODE=false
