# Ibha Web Application Environment Variables
# Copy this file to .env.local and fill in the values

# Catalyst API Base URL
# IMPORTANT: Replace with your actual Catalyst API Gateway URL after deployment
# Format: https://<project-id>.catalyst.zoho.com/baas/v1 or custom domain
# For local development, backend functions are NOT deployed yet
NEXT_PUBLIC_CATALYST_API_BASE_URL=https://api.ibha.catalyst.zoho.com/v1

# Catalyst Auth Configuration
# IMPORTANT: Replace with actual values from Catalyst Console → Auth
# Get these after creating a Catalyst Auth application
NEXT_PUBLIC_CATALYST_AUTH_ISSUER=https://accounts.zoho.com
NEXT_PUBLIC_CATALYST_CLIENT_ID=your_catalyst_client_id_here

# App Configuration
NEXT_PUBLIC_APP_NAME=Ibha
NEXT_PUBLIC_APP_VERSION=0.1.0

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_VOICE_MODE=true
NEXT_PUBLIC_ENABLE_NETWORK_VIEW=true
NEXT_PUBLIC_ENABLE_TRENDS_VIEW=true
NEXT_PUBLIC_ENABLE_INGESTION=true

# Development Settings
NEXT_PUBLIC_DEBUG_MODE=false

# =====================================================
# DEPLOYMENT STATUS (as of setup phase)
# =====================================================
# ❌ Catalyst project: NOT created yet
# ❌ API Gateway: NOT deployed yet
# ❌ Auth app: NOT configured yet
# ❌ Data Store: NOT created yet
# ❌ QuickML: NOT configured yet
# 
# Until deployment, the frontend will fail to connect to backend.
# See /STATUS.md for complete deployment checklist.
