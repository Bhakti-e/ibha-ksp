# Ibha KSP — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ibha
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ── Authentication ──────────────────────────────────────────────────────────
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_strong_random_secret

# ── LLM (optional — system works without this) ─────────────────────────────
# Get a free API key at https://openrouter.ai
# Without this, the system falls back to keyword-based NLP (fully functional).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3.6-27b
OPENROUTER_FALLBACK_MODEL=google/gemma-3-27b-it

# ── Frontend (set this in web/.env.local) ───────────────────────────────────
# Point to wherever the backend is running.
# For local development:
#   NEXT_PUBLIC_CATALYST_API_BASE_URL=http://localhost:8000/api/v1
# For AppSail deployment:
#   NEXT_PUBLIC_CATALYST_API_BASE_URL=https://ibha-ksp-backend.zohocatalyst.com/api/v1
NEXT_PUBLIC_CATALYST_API_BASE_URL=http://localhost:8000/api/v1
